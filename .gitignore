# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
# macOS AppleDouble metadata files (created when copying files from a
# macOS source onto a non-Apple filesystem, e.g. tar from macOS to Linux).
._*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev database
/data/
*.db
*.db-journal
*.sqlite
*.sqlite3

# rust agent build artifacts (Cargo.lock is committed for reproducible binary builds)
/agent/target/

# Claude Code per-project scratch (lock files for scheduled wakeups, etc.)
/.claude/
